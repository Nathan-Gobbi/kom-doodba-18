<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_bike_shop_order">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <div class="row mb-4">
                            <div class="col-8">
                                <h2>
                                    <span t-field="o.name"/>
                                </h2>
                                <p>
                                    <strong>Order Date:</strong>
                                    <span t-field="o.order_date" t-options="{'widget': 'datetime'}"/>
                                </p>
                                <p>
                                    <strong>Status:</strong>
                                    <span t-esc="dict(o._fields['status'].selection).get(o.status)"/>
                                </p>
                            </div>
                            <div class="col-4 text-end">
                                <p>
                                    <strong>Order Number:</strong>
                                    <span t-field="o.name"/>
                                </p>
                            </div>
                        </div>

                        <div class="row mb-4">
                            <div class="col-6">
                                <h3>Customer Information</h3>
                                <p>
                                    <strong>Name:</strong>
                                    <span t-esc="o.partner_name or '-'"/>
                                </p>
                                <p>
                                    <strong>Email:</strong>
                                    <span t-esc="o.partner_email or '-'"/>
                                </p>
                                <p>
                                    <strong>Phone:</strong>
                                    <span t-esc="o.partner_phone or '-'"/>
                                </p>
                                <p>
                                    <strong>Mobile:</strong>
                                    <span t-esc="o.partner_mobile or '-'"/>
                                </p>
                            </div>
                            <div class="col-6">
                                <h3>Address</h3>
                                <p>
                                    <span t-esc="o.partner_street or '-'"/>
                                    <br t-if="o.partner_street2"/>
                                    <span t-if="o.partner_street2" t-esc="o.partner_street2"/>
                                    <br/>
                                    <span t-esc="o.partner_zip or ''"/>
                                    <span t-esc="o.partner_city or ''"/>
                                </p>
                                <p>
                                    <strong>State:</strong>
                                    <span t-esc="o.partner_state_id or '-'"/>
                                </p>
                            </div>
                        </div>

                        <div class="row mb-4">
                            <div class="col-12">
                                <h3>Order Items</h3>
                                <table class="table table-sm">
                                    <thead>
                                        <tr>
                                            <th>Type</th>
                                            <th>Description</th>
                                            <th class="text-end">Quantity</th>
                                            <th class="text-end">Unit Price</th>
                                            <th class="text-end">Total</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr t-foreach="o.order_line_ids" t-as="line">
                                            <td>
                                                <span t-esc="dict(line._fields['line_type'].selection).get(line.line_type)"/>
                                            </td>
                                            <td>
                                                <span t-esc="line.description or '-'"/>
                                            </td>
                                            <td class="text-end">
                                                <span t-esc="'{:.2f}'.format(line.quantity)"/>
                                            </td>
                                            <td class="text-end">
                                                <span t-field="line.unit_price" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                            </td>
                                            <td class="text-end">
                                                <span t-field="line.subtotal" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-6 offset-6">
                                <table class="table table-sm">
                                    <tbody>
                                        <tr>
                                            <td><strong>Subtotal:</strong></td>
                                            <td class="text-end">
                                                <span t-field="o.subtotal" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                            </td>
                                        </tr>
                                        <tr t-if="o.discount_percentage != '0'">
                                            <td>
                                                <strong>Discount (<span t-esc="o.discount_percentage"/>%):</strong>
                                            </td>
                                            <td class="text-end">
                                                <span t-field="o.discount_value" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td><strong>Total:</strong></td>
                                            <td class="text-end">
                                                <strong>
                                                    <span t-field="o.total" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                                </strong>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td><strong>Cost:</strong></td>
                                            <td class="text-end">
                                                <span t-field="o.cost_total" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td><strong>Net Value:</strong></td>
                                            <td class="text-end">
                                                <strong>
                                                    <span t-field="o.net_value" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                                </strong>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <div class="row mt-4" t-if="o.notes">
                            <div class="col-12">
                                <h3>Notes</h3>
                                <p>
                                    <span t-field="o.notes"/>
                                </p>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
