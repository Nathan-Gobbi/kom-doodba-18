<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <menuitem id="menu_bike_shop_root" name="Bike Shop" sequence="60"/>

    <record id="action_bike_shop_product" model="ir.actions.act_window">
        <field name="name">Products</field>
        <field name="res_model">bike_shop.product</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="bike_shop.view_bike_shop_product_search"/>
    </record>

    <record id="action_bike_shop_service" model="ir.actions.act_window">
        <field name="name">Services</field>
        <field name="res_model">bike_shop.service</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="bike_shop.view_bike_shop_service_search"/>
    </record>

    <record id="action_bike_shop_customers" model="ir.actions.act_window">
        <field name="name">Customers</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('customer_rank', '&gt;', 0)]</field>
    </record>

    <record id="action_bike_shop_order" model="ir.actions.act_window">
        <field name="name">Service Orders</field>
        <field name="res_model">bike_shop.order</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="bike_shop.view_bike_shop_order_search"/>
    </record>

    <record id="action_bike_shop_closing" model="ir.actions.act_window">
        <field name="name">Financial Closings</field>
        <field name="res_model">bike_shop.closing</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="bike_shop.view_bike_shop_closing_search"/>
    </record>

    <menuitem id="menu_bike_shop_product" name="Products" parent="bike_shop.menu_bike_shop_root" action="bike_shop.action_bike_shop_product" sequence="10"/>
    <menuitem id="menu_bike_shop_service" name="Services" parent="bike_shop.menu_bike_shop_root" action="bike_shop.action_bike_shop_service" sequence="20"/>
    <menuitem id="menu_bike_shop_customers" name="Customers" parent="bike_shop.menu_bike_shop_root" action="bike_shop.action_bike_shop_customers" sequence="30"/>
    <menuitem id="menu_bike_shop_order" name="Service Orders" parent="bike_shop.menu_bike_shop_root" action="bike_shop.action_bike_shop_order" sequence="40"/>
    <menuitem id="menu_bike_shop_closing" name="Financial Closings" parent="bike_shop.menu_bike_shop_root" action="bike_shop.action_bike_shop_closing" sequence="50"/>
</odoo>
