<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_bike_shop_service_list" model="ir.ui.view">
        <field name="name">bike.shop.service.list</field>
        <field name="model">bike_shop.service</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="price"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_bike_shop_service_form" model="ir.ui.view">
        <field name="name">bike.shop.service.form</field>
        <field name="model">bike_shop.service</field>
        <field name="arch" type="xml">
            <form string="Service">
                <sheet>
                    <widget name="web_ribbon" title="Archived" invisible="active"/>
                    <field name="active" invisible="1"/>
                    <field name="company_id" invisible="1"/>
                    <field name="currency_id" invisible="1"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Service Name"/>
                        </h1>
                    </div>
                    <group string="Pricing">
                        <field name="price"/>
                    </group>
                    <group string="Description">
                        <field name="description" placeholder="Service description..." nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_bike_shop_service_search" model="ir.ui.view">
        <field name="name">bike.shop.service.search</field>
        <field name="model">bike_shop.service</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="Service Name"/>
                <separator/>
                <filter name="active_services" string="Active" domain="[('active', '=', True)]"/>
                <filter name="archived_services" string="Archived" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>
</odoo>
