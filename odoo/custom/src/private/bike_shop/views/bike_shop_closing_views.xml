<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_bike_shop_closing_list" model="ir.ui.view">
        <field name="name">bike.shop.closing.list</field>
        <field name="model">bike_shop.closing</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="quantity_orders"/>
                <field name="total_sales"/>
                <field name="net_value"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_bike_shop_closing_form" model="ir.ui.view">
        <field name="name">bike.shop.closing.form</field>
        <field name="model">bike_shop.closing</field>
        <field name="arch" type="xml">
            <form string="Financial Closing">
                <header>
                    <button name="action_complete" string="Complete Closing" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_reset" string="Reset to Draft" type="object" invisible="state != 'done'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,done"/>
                </header>
                <sheet>
                    <field name="company_id" invisible="1"/>
                    <field name="currency_id" invisible="1"/>
                    <widget name="web_ribbon" title="Completed" bg_color="text-bg-success" invisible="state != 'done'"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group string="Period">
                        <group>
                            <field name="date_start" readonly="state == 'done'"/>
                        </group>
                        <group>
                            <field name="date_end" readonly="state == 'done'"/>
                        </group>
                    </group>
                    <group string="Consolidation Summary">
                        <group>
                            <field name="quantity_orders" readonly="1"/>
                            <field name="total_products_sales" readonly="1"/>
                            <field name="total_services_sales" readonly="1"/>
                        </group>
                        <group>
                            <field name="total_sales" readonly="1"/>
                            <field name="total_discounts" readonly="1"/>
                            <field name="total_product_costs" readonly="1"/>
                        </group>
                    </group>
                    <group string="Result">
                        <field name="net_value" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_bike_shop_closing_search" model="ir.ui.view">
        <field name="name">bike.shop.closing.search</field>
        <field name="model">bike_shop.closing</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="Closing Period"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <separator/>
                <filter name="draft_closings" string="Draft" domain="[('state', '=', 'draft')]"/>
                <filter name="completed_closings" string="Completed" domain="[('state', '=', 'done')]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter name="group_by_state" string="State" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>
</odoo>
