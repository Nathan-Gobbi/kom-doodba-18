<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_bike_shop_product_list" model="ir.ui.view">
        <field name="name">bike.shop.product.list</field>
        <field name="model">bike_shop.product</field>
        <field name="arch" type="xml">
            <list>
                <field name="code"/>
                <field name="name"/>
                <field name="color"/>
                <field name="stock"/>
                <field name="selling_price"/>
                <field name="cost_price"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_bike_shop_product_form" model="ir.ui.view">
        <field name="name">bike.shop.product.form</field>
        <field name="model">bike_shop.product</field>
        <field name="arch" type="xml">
            <form string="Product">
                <sheet>
                    <widget name="web_ribbon" title="Archived" invisible="active"/>
                    <field name="active" invisible="1"/>
                    <field name="company_id" invisible="1"/>
                    <field name="currency_id" invisible="1"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Product Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="code" placeholder="e.g. PROD-001"/>
                            <field name="barcode" placeholder="EAN-13"/>
                            <field name="ncm" placeholder="e.g. 8712.90.20"/>
                        </group>
                        <group>
                            <field name="color" placeholder="e.g. Red, Blue"/>
                            <field name="stock"/>
                        </group>
                    </group>
                    <group string="Pricing">
                        <group>
                            <field name="cost_price"/>
                        </group>
                        <group>
                            <field name="selling_price"/>
                        </group>
                    </group>
                    <group string="Description">
                        <field name="description" placeholder="Product description..." nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_bike_shop_product_search" model="ir.ui.view">
        <field name="name">bike.shop.product.search</field>
        <field name="model">bike_shop.product</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="Product Name or Code" filter_domain="['|', ('name', 'ilike', self), ('code', 'ilike', self)]"/>
                <field name="code"/>
                <field name="barcode"/>
                <field name="color"/>
                <separator/>
                <filter name="in_stock" string="In Stock" domain="[('stock', '&gt;', 0)]"/>
                <filter name="out_of_stock" string="Out of Stock" domain="[('stock', '&lt;=', 0)]"/>
                <filter name="active_products" string="Active" domain="[('active', '=', True)]"/>
                <filter name="archived_products" string="Archived" domain="[('active', '=', False)]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter name="group_by_color" string="Color" context="{'group_by': 'color'}"/>
                    <filter name="group_by_active" string="Status" context="{'group_by': 'active'}"/>
                </group>
            </search>
        </field>
    </record>
</odoo>
