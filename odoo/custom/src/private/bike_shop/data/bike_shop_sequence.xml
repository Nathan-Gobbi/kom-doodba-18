<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Sequence for Service Orders -->
        <record id="seq_bike_shop_order" model="ir.sequence">
            <field name="name">Bike Shop Order</field>
            <field name="code">bike_shop.order</field>
            <field name="prefix">BSO/%(year)s/</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>
